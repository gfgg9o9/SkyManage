{
  "entities": {
    "User": {
      "title": "User",
      "description": "User profile information synchronized from Firebase Auth.",
      "type": "object",
      "properties": {
        "displayName": { "type": "string" },
        "email": { "type": "string", "format": "email" },
        "photoURL": { "type": "string" },
        "lastLogin": { "type": "string", "format": "date-time" }
      },
      "required": ["displayName", "email"]
    },
    "Project": {
      "title": "Project",
      "description": "A top-level project container.",
      "type": "object",
      "properties": {
        "name": { "type": "string" },
        "description": { "type": "string" },
        "ownerId": { "type": "string" },
        "members": { "type": "array", "items": { "type": "string" } },
        "createdAt": { "type": "string", "format": "date-time" },
        "updatedAt": { "type": "string", "format": "date-time" }
      },
      "required": ["name", "ownerId", "members"]
    },
    "Task": {
      "title": "Task",
      "description": "A specific task within a project.",
      "type": "object",
      "properties": {
        "projectId": { "type": "string" },
        "title": { "type": "string" },
        "description": { "type": "string" },
        "status": { "type": "string", "enum": ["todo", "in_progress", "done"] },
        "priority": { "type": "string", "enum": ["low", "medium", "high", "urgent"] },
        "assigneeId": { "type": "string" },
        "reporterId": { "type": "string" },
        "dueDate": { "type": "string", "format": "date-time" },
        "createdAt": { "type": "string", "format": "date-time" },
        "updatedAt": { "type": "string", "format": "date-time" }
      },
      "required": ["projectId", "title", "status", "priority", "reporterId"]
    },
    "Comment": {
      "title": "Comment",
      "description": "User comments on tasks.",
      "type": "object",
      "properties": {
        "taskId": { "type": "string" },
        "authorId": { "type": "string" },
        "text": { "type": "string" },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["taskId", "authorId", "text"]
    },
    "Notification": {
      "title": "Notification",
      "description": "System-generated notifications for users.",
      "type": "object",
      "properties": {
        "userId": { "type": "string" },
        "type": { "type": "string" },
        "message": { "type": "string" },
        "projectId": { "type": "string" },
        "taskId": { "type": "string" },
        "read": { "type": "boolean" },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["userId", "message", "read"]
    },
    "TerminalEvent": {
      "title": "TerminalEvent",
      "description": "Real-time action logs for the terminal.",
      "type": "object",
      "properties": {
        "type": { "type": "string" },
        "userId": { "type": "string" },
        "userName": { "type": "string" },
        "projectId": { "type": "string" },
        "projectName": { "type": "string" },
        "taskId": { "type": "string" },
        "taskTitle": { "type": "string" },
        "details": { "type": "string" },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["type", "userId", "userName", "details", "createdAt"]
    }
  },
  "firestore": {
    "users/{userId}": {
      "schema": "User",
      "description": "User profiles."
    },
    "projects/{projectId}": {
      "schema": "Project",
      "description": "Project documents."
    },
    "tasks/{taskId}": {
      "schema": "Task",
      "description": "Task documents."
    },
    "tasks/{taskId}/comments/{commentId}": {
      "schema": "Comment",
      "description": "Comments on tasks."
    },
    "notifications/{notificationId}": {
      "schema": "Notification",
      "description": "In-app notifications."
    },
    "terminal_events/{eventId}": {
      "schema": "TerminalEvent",
      "description": "System-wide action events."
    }
  }
}
