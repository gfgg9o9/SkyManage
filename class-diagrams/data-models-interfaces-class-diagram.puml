' Enums
enum Priority {
    LOW
    MEDIUM
    HIGH
    URGENT
}

enum Status {
    TODO
    IN_PROGRESS
    DONE
    BLOCKED
    CANCELLED
}

enum Role {
    ADMIN
    PM
    MEMBER
    VIEWER
}

enum NotificationType {
    TASK_ASSIGNED
    TASK_UPDATED
    COMMENT_ADDED
    PROJECT_INVITE
    SYSTEM_NOTIFICATION
    MENTION
    DEADLINE_REMINDER
}

enum EventType {
    TASK_MOVE
    STATUS_CHANGE
    USER_JOIN
    PROJECT_CREATE
    COMMENT_ADD
    FILE_UPLOAD
    LOGIN
    LOGOUT
}

' Interfaces
interface IDataModel {
    +id: string
    +toJSON(): JSON
    +validate(): ValidationResult
    +fromJSON(data: JSON): IDataModel
}

interface IAuditable {
    +createdAt: string
    +updatedAt: string
    +createdBy?: string
    +updatedBy?: string
    +getAuditTrail(): AuditEntry[]
}

interface ITimestamped {
    +createdAt: string
    +updatedAt: string
    +getTimeSinceCreation(): string
    +isRecentlyUpdated(): boolean
}

interface ISearchable {
    +getSearchTerms(): string[]
    +matches(query: string): boolean
    +getSearchScore(query: string): number
}

interface INotifiable {
    +getNotificationRecipients(): string[]
    +getNotificationMessage(action: string): string
    +shouldNotify(action: string): boolean
}

