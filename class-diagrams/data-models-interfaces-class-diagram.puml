' Model Relationships
User "1" -- "*" Project : "owns"
User "1" -- "*" Task : "assigned to"
User "1" -- "*" Comment : "author"
User "1" -- "*" Notification : "recipient"
User "1" -- "*" TerminalEvent : "actor"

Project "1" -- "*" Task : "contains"
Project "1" -- "*" ProjectMember : "has"
Project "1" -- "*" Invitation : "sends"
Project "1" -- "*" AIInsight : "generates"
Project "1" -- "*" ProjectAnalytics : "analyzes"

Task "1" -- "*" Comment : "has"
Task "1" -- "*" FileAttachment : "contains"
Task "*" -- "*" Task : "depends on"

User "1" -- "1" UserSettings : "has"
User "1" -- "1" UserBehavior : "tracks"

Project "1" -- "1" ProjectSettings : "has"

' Type Associations
Task -- Priority : "has"
Task -- Status : "has"
ProjectMember -- Role : "has"
Notification -- NotificationType : "has"
TerminalEvent -- EventType : "has"

' Composition Relationships
ProjectMember --> User : "references"
Invitation --> Project : "references"
FileAttachment --> User : "uploaded by"
ActivityLog --> User : "performed by"
SystemMetrics --> System : "monitors"

' Aggregation Relationships
ProjectAnalytics --> AIInsight : "aggregates"
UserBehavior --> ActivityLog : "analyzes"
SearchQuery --> SearchResult : "produces"

