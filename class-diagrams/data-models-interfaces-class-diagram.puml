' Core Data Models
class User {
    +uid: string
    +displayName: string
    +email: string
    +photoURL?: string
    +lastLogin?: string
    +createdAt: string
    +updatedAt: string
    +settings: UserSettings
    +isActive: boolean
    +preferences: UserPreferences
    +getEmail(): string
    +getDisplayName(): string
    +updateProfile(updates: Partial<User>): void
    +toJSON(): UserJSON
    +validate(): ValidationResult
}

class Project {
    +id: string
    +name: string
    +description: string
    +ownerId: string
    +members: string[]
    +admins?: string[]
    +pms?: string[]
    +memberDetails?: ProjectMember[]
    +settings: ProjectSettings
    +createdAt: string
    +updatedAt: string
    +status: ProjectStatus
    +tags: string[]
    +addMember(member: ProjectMember): void
    +removeMember(userId: string): void
    +updateSettings(settings: Partial<ProjectSettings>): void
    +isMember(userId: string): boolean
    +isAdmin(userId: string): boolean
    +toJSON(): ProjectJSON
}

class Task {
    +id: string
