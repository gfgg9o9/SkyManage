@startuml SkyManage Main Architecture Class Diagram

title SkyManage - Main Architecture Class Diagram
skinparam class {
    BackgroundColor #LightBlue
    BorderColor #DarkBlue
    ArrowColor #DarkBlue
}
skinparam interface {
    BackgroundColor #LightGreen
    BorderColor #DarkGreen
    ArrowColor #DarkGreen
}
skinparam package {
    BackgroundColor #LightGray
    BorderColor #Black
}

' Package Declarations
package "Frontend (React)" {
    class App
    class AuthProvider
    class Layout
    class Dashboard
    class Projects
    class Settings
    class MissionControl
    class NeuralNetwork
    class TerminalLog
}

package "Backend (Express)" {
    class Server
    class APIRouter
    class AuthMiddleware
    class ErrorHandler
}

package "Database Layer" {
    interface IFirestoreService
    class FirestoreService
    interface IMongoService
    class MongoService
}

package "External Services" {
    class FirebaseAuthentication
    class FirebaseFirestore
    class GoogleGenerativeAI
    class AWSS3
    class EmailService
}

package "Data Models" {
    class User
    class Project
    class Task
    class Comment
    class Notification
    class TerminalEvent
}

package "Hooks (React Custom Hooks)" {
    class useAuth
    class useProjects
    class useTasks
    class useComments
    class useNotifications
    class useTerminalEvents
}

' Frontend Classes
class App {
    -state: AppState
    +render(): JSX.Element
    +handleTabChange(tab: string): void
    +handleProjectSelect(projectId: string): void
}

class AuthProvider {
    -user: User | null
    -loading: boolean
    +signIn(): Promise<void>
    +logout(): Promise<void>
    +getUser(): User | null
}

class Layout {
    -activeTab: string
    -searchQuery: string
    +renderNavigation(): JSX.Element
    +handleSearch(query: string): void
    +handleTabNavigation(tab: string): void
}

class Dashboard {
    -projects: Project[]
    -tasks: Task[]
    +renderProjectOverview(): JSX.Element
    +renderTaskSummary(): JSX.Element
    +renderActivityFeed(): JSX.Element
}

class Projects {
    -projects: Project[]
    -selectedProject: Project | null
    +renderProjectList(): JSX.Element
    +handleProjectCreate(project: Project): void
    +handleProjectUpdate(project: Project): void
}

class Settings {
    -userSettings: UserSettings
    +renderUserPreferences(): JSX.Element
    +handleSettingsUpdate(settings: UserSettings): void
}

class MissionControl {
    -systemMetrics: SystemMetrics
    +renderSystemStatus(): JSX.Element
    +renderPerformanceMetrics(): JSX.Element
}

class NeuralNetwork {
    -aiData: AIData
    +renderAIVisualization(): JSX.Element
    +processAIInput(input: string): Promise<AIResponse>
}

class TerminalLog {
    -events: TerminalEvent[]
    +renderTerminalOutput(): JSX.Element
    +filterEvents(filter: EventFilter): TerminalEvent[]
}

' Backend Classes
class Server {
    -app: Express
    -port: number
    +start(): void
    +setupMiddleware(): void
    +setupRoutes(): void
}

class APIRouter {
    +handleInvite(req: Request, res: Response): Promise<void>
    +handleUpload(req: Request, res: Response): Promise<void>
    +handleNotification(req: Request, res: Response): Promise<void>
    +handleHealthCheck(req: Request, res: Response): void
}

class AuthMiddleware {
    +verifyToken(req: Request, res: Response, next: NextFunction): void
    +checkPermissions(permission: string): MiddlewareFunction
}

class ErrorHandler {
    +handleError(error: Error, req: Request, res: Response): void
    +logError(error: Error): void
}

' Database Layer
interface IFirestoreService {
    +connect(): Promise<void>
    +createDocument(collection: string, data: any): Promise<string>
    +getDocument(collection: string, id: string): Promise<any>
    +updateDocument(collection: string, id: string, data: any): Promise<void>
    +deleteDocument(collection: string, id: string): Promise<void>
    +queryDocuments(collection: string, queries: Query[]): Promise<any[]>
}

class FirestoreService {
    -db: Firestore
    -auth: Auth
    +connect(): Promise<void>
    +createDocument(collection: string, data: any): Promise<string>
    +getDocument(collection: string, id: string): Promise<any>
    +updateDocument(collection: string, id: string, data: any): Promise<void>
    +deleteDocument(collection: string, id: string): Promise<void>
    +queryDocuments(collection: string, queries: Query[]): Promise<any[]>
    +setupRealtimeListener(collection: string, callback: Function): Unsubscribe
}

interface IMongoService {
    +connect(): Promise<void>
    +insertOne(collection: string, document: any): Promise<InsertResult>
    +findOne(collection: string, filter: any): Promise<any>
    +updateOne(collection: string, filter: any, update: any): Promise<UpdateResult>
    +deleteOne(collection: string, filter: any): Promise<DeleteResult>
    +find(collection: string, filter: any): Promise<any[]>
}

class MongoService {
    -client: MongoClient
    -database: Db
    +connect(): Promise<void>
    +insertOne(collection: string, document: any): Promise<InsertResult>
    +findOne(collection: string, filter: any): Promise<any>
    +updateOne(collection: string, filter: any, update: any): Promise<UpdateResult>
    +deleteOne(collection: string, filter: any): Promise<DeleteResult>
    +find(collection: string, filter: any): Promise<any[]>
}

' External Services
class FirebaseAuthentication {
    +signInWithPopup(provider: AuthProvider): Promise<UserCredential>
    +signOut(): Promise<void>
    +onAuthStateChanged(callback: Function): Unsubscribe
    +createUserWithEmailAndPassword(email: string, password: string): Promise<UserCredential>
}

class FirebaseFirestore {
    +collection(collectionName: string): CollectionReference
    +doc(documentPath: string): DocumentReference
    +runTransaction(updateFunction: Function): Promise<any>
}

class GoogleGenerativeAI {
    -apiKey: string
    +generateText(prompt: string): Promise<string>
    +analyzeProjectData(data: ProjectData): Promise<AIInsights>
    +suggestTasks(context: ProjectContext): Promise<Task[]>
}

class AWSS3 {
    -client: S3Client
    +generateUploadUrl(fileName: string, fileType: string): Promise<string>
    +uploadFile(key: string, body: Buffer): Promise<UploadResult>
    +deleteFile(key: string): Promise<void>
}

class EmailService {
    +sendInvitation(email: string, projectData: ProjectData): Promise<void>
    +sendNotification(email: string, notification: Notification): Promise<void>
    +sendPasswordReset(email: string, resetLink: string): Promise<void>
}

' Data Models
class User {
    +uid: string
    +displayName: string
    +email: string
    +photoURL?: string
    +lastLogin?: string
}

class Project {
    +id: string
    +name: string
    +description: string
    +ownerId: string
    +members: string[]
    +admins?: string[]
    +pms?: string[]
    +memberDetails?: ProjectMember[]
    +createdAt: string
    +updatedAt: string
}

class Task {
    +id: string
    +projectId: string
    +title: string
    +description: string
    +status: Status
    +priority: Priority
    +assigneeId?: string
    +reporterId: string
    +dueDate?: string
    +progress: number
    +createdAt: string
    +updatedAt: string
}

class Comment {
    +id: string
    +taskId: string
    +authorId: string
    +authorName?: string
    +authorPhoto?: string
    +content: string
    +createdAt: string
}

class Notification {
    +id: string
    +userId: string
    +type: string
    +message: string
    +projectId?: string
    +taskId?: string
    +read: boolean
    +createdAt: string
}

class TerminalEvent {
    +id: string
    +type: EventType
    +userId: string
    +userName: string
    +projectId?: string
    +projectName?: string
    +taskId?: string
    +taskTitle?: string
    +details: string
    +createdAt: string
}

' React Hooks
class useAuth {
    +user: User | null
    +loading: boolean
    +signIn(): Promise<void>
    +logout(): Promise<void>
}

class useProjects {
    +projects: Project[]
    +loading: boolean
    +createProject(name: string, description: string): Promise<void>
    +deleteProject(projectId: string): Promise<void>
    +updateProject(projectId: string, updates: Partial<Project>): Promise<void>
    +addProjectMember(projectId: string, email: string, role: Role): Promise<void>
    +removeProjectMember(projectId: string, userId: string): Promise<void>
}

class useTasks {
    +tasks: Task[]
    +loading: boolean
    +createTask(task: Partial<Task>): Promise<void>
    +updateTask(taskId: string, updates: Partial<Task>): Promise<void>
    +deleteTask(taskId: string): Promise<void>
}

class useComments {
    +comments: Comment[]
    +loading: boolean
    +addComment(content: string): Promise<void>
    +deleteComment(commentId: string): Promise<void>
}

class useNotifications {
    +notifications: Notification[]
    +markAsRead(notificationId: string): Promise<void>
    +createNotification(data: Partial<Notification>): Promise<void>
}

class useTerminalEvents {
    +events: TerminalEvent[]
    +loading: boolean
}

' Relationships
App --> AuthProvider
App --> Layout
Layout --> Dashboard
Layout --> Projects
Layout --> Settings
Layout --> MissionControl
Layout --> NeuralNetwork
Layout --> TerminalLog

AuthProvider --> FirebaseAuthentication
AuthProvider --> User

Dashboard --> useProjects
Dashboard --> useTasks
Projects --> useProjects
Settings --> useAuth

useAuth --> FirebaseAuthentication
useProjects --> FirestoreService
useTasks --> FirestoreService
useComments --> FirestoreService
useNotifications --> FirestoreService
useTerminalEvents --> FirestoreService

FirestoreService ..|> IFirestoreService
MongoService ..|> IMongoService

Server --> APIRouter
Server --> AuthMiddleware
APIRouter --> EmailService
APIRouter --> AWSS3
APIRouter --> GoogleGenerativeAI

FirestoreService --> FirebaseFirestore
MongoService --> MongoClient

' Data Model Relationships
Project --> User : "owner"
Project --> User : "members"
Task --> Project : "belongs to"
Task --> User : "assignee"
Comment --> Task : "belongs to"
Comment --> User : "author"
Notification --> User : "recipient"
TerminalEvent --> User : "actor"
TerminalEvent --> Project : "context"

@enduml
