' Relationships and Dependencies
UC1 ..> UC32 : <<include>>
UC2 ..> UC6 : <<extend>>
UC7 ..> UC8 : <<include>>
UC10 ..> UC7 : <<extend>>
UC13 ..> UC15 : <<extend>>
UC19 ..> UC21 : <<include>>
UC20 ..> UC21 : <<extend>>
UC22 ..> UC19 : <<extend>>
UC25 ..> UC26 : <<include>>
UC29 ..> UC32 : <<extend>>
UC29 ..> UC33 : <<extend>>
UC34 ..> UC35 : <<include>>

' Use Case Groupings
package "Invitation Management" {
    UC1
    UC2
    UC3
    UC4
    UC5
    UC6
}

package "Real-time Communication" {
    UC7
    UC8
    UC9
    UC10
    UC11
    UC12
}

package "File Collaboration" {
    UC19
