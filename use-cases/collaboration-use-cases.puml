@startuml SkyManage Collaboration Use Cases

title SkyManage - Collaboration Features Use Cases
skinparam actorStyle awesome
skinparam usecase {
    BackgroundColor #LightPink
    BorderColor #DarkRed
    ArrowColor #DarkRed
}
skinparam rectangle {
    BackgroundColor #LightYellow
    BorderColor #Black
}

' Actors
actor "Team Member" as TM
actor "Project Manager" as PM
actor "External Collaborator" as External
actor "Email Service" as Email
actor "File Storage" as Storage

' System Boundary
rectangle "Collaboration Module" {
    ' Invitation System
    usecase "Send Project Invitation" as UC1
    usecase "Accept Invitation" as UC2
    usecase "Decline Invitation" as UC3
    usecase "Resend Invitation" as UC4
    usecase "Revoke Invitation" as UC5
    usecase "Manage Pending Invitations" as UC6
    
    ' Real-time Communication
    usecase "Start Chat Session" as UC7
    usecase "Send Message" as UC8
    usecase "Share Files in Chat" as UC9
    usecase "Create Group Chat" as UC10
    usecase "Video Conference" as UC11
    usecase "Screen Sharing" as UC12
    
    ' Comments and Mentions
    usecase "Add Comment to Task" as UC13
    usecase "Reply to Comments" as UC14
    usecase "Mention Team Members" as UC15
    usecase "Edit Comments" as UC16
    usecase "Delete Comments" as UC17
    usecase "Resolve Comments" as UC18
    
    ' File Sharing and Collaboration
    usecase "Upload Files" as UC19
    usecase "Share Files" as UC20
    usecase "Set File Permissions" as UC21
    usecase "Version Control" as UC22
    usecase "Preview Files" as UC23
    usecase "Download Files" as UC24
    
    ' Activity Tracking
    usecase "View Activity Feed" as UC25
    usecase "Track User Activity" as UC26
    usecase "Generate Activity Reports" as UC27
    usecase "Set Activity Notifications" as UC28
    
    ' Notification System
    usecase "Send Notification" as UC29
    usecase "Manage Notification Preferences" as UC30
    usecase "Mark Notifications Read" as UC31
    usecase "Email Notifications" as UC32
    usecase "Push Notifications" as UC33
    
    ' Access Control
    usecase "Assign Roles" as UC34
    usecase "Manage Permissions" as UC35
    usecase "Create Access Groups" as UC36
    usecase "Audit Access Changes" as UC37
}

