# Resend API Key for sending invite emails
# Get one at https://resend.com
# NOTE: Trial accounts can only send emails to the owner's email address.
# To send to others, you MUST verify a domain in your Resend dashboard.
RESEND_API_KEY=

# AWS S3 Configuration
# Required for project document uploads
AWS_REGION=
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_BUCKET_NAME=
